---
// Lists the most recent blog posts on the blog index page (en/blog/index.mdx).
// Posts come from the docs collection under en/blog/, ordered by pubDate
// descending; posts without a pubDate sort last.
import { getCollection } from 'astro:content';

interface Props {
	count?: number;
}

const { count = 5 } = Astro.props;

const posts = (await getCollection('docs', (entry) => entry.id.startsWith('en/blog/')))
	.sort((a, b) => (b.data.pubDate?.getTime() ?? 0) - (a.data.pubDate?.getTime() ?? 0))
	.slice(0, count);

const formatter = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });
---

<ul>
	{
		posts.map((post) => (
			<li>
				<a href={`/${post.id}/`}>{post.data.title}</a>
				{post.data.pubDate && (
					<>
						{' '}
						(<time datetime={post.data.pubDate.toISOString().slice(0, 10)}>
							{formatter.format(post.data.pubDate)}
						</time>)
					</>
				)}{' '}
				— {post.data.description}
			</li>
		))
	}
</ul>
