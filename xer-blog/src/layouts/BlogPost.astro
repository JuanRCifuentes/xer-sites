---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getBucketImageUrl } from '../utils/images';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
const heroImageUrl = heroImage ? getBucketImageUrl(heroImage) : undefined;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			/* Mermaid diagrams are generated in the DOM at runtime by the mermaid
			   library (and the <svg> by mermaid internally), so these elements
			   can't carry Tailwind utility classes. */
			:global(.mermaid) {
				margin: 2rem 0;
				overflow: visible;
				text-align: center;
			}
			:global(.mermaid svg) {
				max-width: 100%;
				height: auto;
			}
		</style>
	</head>

	<body>
		<Header />
		<main class="m-0 w-[calc(100%-2em)] max-w-full px-[1em] py-[3em] mobile:py-[1em]">
			<article>
				<div class="w-full">
					{
						heroImageUrl && (
							<img
								width="1020"
								height="510"
								src={heroImageUrl}
								alt={heroImage?.alt ?? ''}
								class="mx-auto block rounded-xl shadow-[var(--box-shadow)]"
							/>
						)
					}
				</div>
				<div class="prose mx-auto w-[720px] max-w-[calc(100%-2em)] p-[1em] text-[rgb(var(--gray-dark))]">
					<div class="mb-[1em] py-[1em] text-center leading-none">
						<div class="mb-[0.5em] text-[rgb(var(--gray))]">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="italic">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1 class="m-0 mb-[0.5em]">{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			import mermaid from 'mermaid';

			mermaid.initialize({
				startOnLoad: false,
				theme: 'default',
				securityLevel: 'strict',
				themeVariables: {
					fontSize: '24px',
				},
				flowchart: {
					htmlLabels: true,
					nodeSpacing: 70,
					rankSpacing: 80,
					useMaxWidth: true,
				},
			});

			const wrapMermaidLabel = (label: string, maxLineLength = 16) => {
				if (label.includes('<br') || label.length <= maxLineLength) {
					return label;
				}

				const lines = [];
				let currentLine = '';

				for (const word of label.split(/\s+/)) {
					const nextLine = currentLine ? `${currentLine} ${word}` : word;

					if (nextLine.length > maxLineLength && currentLine) {
						lines.push(currentLine);
						currentLine = word;
					} else {
						currentLine = nextLine;
					}
				}

				if (currentLine) {
					lines.push(currentLine);
				}

				return lines.join('<br/>');
			};

			const wrapMermaidNodeLabels = (source: string) =>
				source.replace(/(\b[\w-]+\s*(?:\[\s*"|\{\s*"|\(\s*"))([^"]+)((?:"\s*\]|\s*"\}|\s*"\)))/g, (_, start, label, end) => {
					return `${start}${wrapMermaidLabel(label)}${end}`;
				});

			const normalizeMermaidSource = (source: string) => {
				const shouldPreserveLayout = source.includes('%% mermaid-preserve-layout %%');
				const readableSource = shouldPreserveLayout
					? source
					: source.replace(/^(\s*(?:flowchart|graph)\s+)(LR|RL)(\s*)$/m, '$1TD$3');

				return wrapMermaidNodeLabels(readableSource);
			};

			const mermaidBlocks = Array.from(
				document.querySelectorAll('pre[data-language="mermaid"] > code, pre > code.language-mermaid'),
			);
			const diagrams = mermaidBlocks.map((block) => {
				const diagram = document.createElement('div');
				diagram.className = 'mermaid';
				const lines = Array.from(block.querySelectorAll('.line'));
				const source = lines.length > 0 ? lines.map((line) => line.textContent ?? '').join('\n') : block.textContent;
				diagram.textContent = normalizeMermaidSource(source ?? '');
				block.parentElement?.replaceWith(diagram);
				return diagram;
			});

			if (diagrams.length > 0) {
				await mermaid.run({ nodes: diagrams });
			}
		</script>
	</body>
</html>
