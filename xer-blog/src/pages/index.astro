---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getBucketImageUrl } from '../utils/images';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="mx-auto w-[960px] max-w-[calc(100%-2em)] px-[1em] py-[3em] mobile:py-[1em]">
			<section>
				<ul class="m-0 flex list-none flex-wrap gap-8 p-0 mobile:gap-[0.5em]">
					{
						posts.map((post, index) => {
							const featured = index === 0;
							return (
								<li
									class:list={[
										'mobile:w-full mobile:text-center',
										featured ? 'mb-4 w-full text-center mobile:mb-0' : 'w-[calc(50%-1rem)]',
									]}
								>
									<a href={`/blog/${post.id}/`} class="group block no-underline">
										{post.data.heroImage && (
											<img
												width="720"
												height="360"
												src={getBucketImageUrl(post.data.heroImage)}
												alt={post.data.heroImage.alt ?? ''}
												class:list={[
													'mb-2 rounded-xl transition-all duration-200 ease-[ease] group-hover:shadow-[var(--box-shadow)]',
													featured && 'w-full',
												]}
											/>
										)}
										<h4
											class:list={[
												'm-0 leading-none text-[rgb(var(--black))] transition-all duration-200 ease-[ease] group-hover:text-[rgb(var(--accent))]',
												featured && 'text-[2.369rem] mobile:text-[1.563em]',
											]}
										>
											{post.data.title}
										</h4>
										<p class="m-0 text-[rgb(var(--gray))] transition-all duration-200 ease-[ease] group-hover:text-[rgb(var(--accent))]">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
