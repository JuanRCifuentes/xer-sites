---
import { getEntry } from "astro:content";
import Header from '../../components/Header.astro';
import AiBanner from "../../components/AiBanner.astro";
import Hero from '../../components/landing/Hero.astro';
import LogoCloud from '../../components/landing/LogoCloud.astro';
import PrimaryFeatures from '../../components/landing/PrimaryFeatures.astro';
import SecondaryFeatures from '../../components/landing/SecondaryFeatures.astro';
import Stats from '../../components/landing/Stats.astro';
import CtaBanner from '../../components/landing/CtaBanner.astro';
import Footer from '../../components/landing/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { LOCALES, STRINGS, type Lang } from '../../i18n';
import '../../styles/global.css';

export function getStaticPaths() {
	return Object.keys(LOCALES).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const { dir } = LOCALES[lang];
const t = STRINGS[lang];

const entry = (await getEntry("landing", lang)) ?? (await getEntry("landing", "en"));
if (!entry) throw new Error("Missing landing content for " + lang);
const data = entry.data;
---

<html lang={lang} dir={dir}>
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			// Apply the stored theme before first paint to avoid a flash of the
			// wrong color scheme. Mirrors the logic in ThemeSelect.astro.
			(() => {
				let pref = null;
				try {
					pref = localStorage.getItem('theme');
				} catch {
					/* localStorage unavailable */
				}
				const dark =
					pref === 'dark' ||
					(pref !== 'light' && window.matchMedia('(prefers-color-scheme: dark)').matches);
				document.documentElement.dataset.theme = dark ? 'dark' : 'light';
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{data.meta?.title ?? SITE_TITLE}</title>
		<meta name="description" content={data.meta?.description ?? t.description} />
	</head>
	<body class="bg-white dark:bg-gray-900">
		<Header lang={lang} />
		<AiBanner lang={lang} />
		<div class="bg-white dark:bg-gray-900">
			<main>
				<Hero section={data.hero} lang={lang} />
				<LogoCloud section={data.logoCloud} />
				<PrimaryFeatures section={data.primaryFeatures} lang={lang} />
				<SecondaryFeatures section={data.secondaryFeatures} />
				<Stats section={data.stats} />
				<CtaBanner section={data.cta} lang={lang} />
			</main>
			<Footer section={data.footer} />
		</div>
	</body>
</html>
