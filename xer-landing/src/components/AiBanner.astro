---
// Localized "AI Generated" warning for machine-translated locales, mirroring
// the Banner override on the docs site (xer-docs/src/components/Banner.astro).
// English and Spanish are human-maintained, so they get no warning; every
// other locale does. Keys match src/i18n.ts.
import type { Lang } from "../i18n";

interface Props {
	lang: Lang;
}

const AI_WARNINGS: Partial<Record<Lang, string>> = {
	"zh": "本页面由 AI 自动翻译，可能存在错误。",
	"ar": "تمت ترجمة هذه الصفحة آلياً بواسطة الذكاء الاصطناعي وقد تحتوي على أخطاء.",
	"hi": "यह पृष्ठ AI द्वारा स्वचालित रूप से अनुवादित किया गया है और इसमें त्रुटियाँ हो सकती हैं।",
	"pt": "Esta página foi traduzida automaticamente por IA e pode conter erros.",
	"ru": "Эта страница была переведена автоматически с помощью ИИ и может содержать ошибки.",
	"fr": "Cette page a été traduite automatiquement par une IA et peut contenir des erreurs.",
	"de": "Diese Seite wurde automatisch von einer KI übersetzt und kann Fehler enthalten.",
	"ko": "이 페이지는 AI에 의해 자동 번역되었으며 오류가 있을 수 있습니다.",
	"ja": "このページは AI によって自動翻訳されているため、誤りが含まれている可能性があります。",
	"it": "Questa pagina è stata tradotta automaticamente da un'IA e potrebbe contenere errori."
};

const { lang } = Astro.props;
const warning = AI_WARNINGS[lang];
---

{
	warning && (
		<div
			role="note"
			class="flex items-center justify-center gap-x-2.5 border-b border-amber-300 bg-amber-50 px-6 py-2.5 text-center text-sm/6 font-medium text-amber-900 dark:border-amber-400/30 dark:bg-amber-400/10 dark:text-amber-200"
		>
			<svg
				class="size-4 shrink-0"
				aria-hidden="true"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
				<line x1="12" y1="9" x2="12" y2="13" />
				<line x1="12" y1="17" x2="12.01" y2="17" />
			</svg>
			<span dir="auto">{warning}</span>
		</div>
	)
}
