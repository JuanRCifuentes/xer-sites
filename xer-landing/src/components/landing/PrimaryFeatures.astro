---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "../../i18n";
import Icon from "./Icon.astro";
import { resolveHref } from "../../lib/links";

type Props = {
	section: CollectionEntry<"landing">["data"]["primaryFeatures"];
	lang: Lang;
};

const { section, lang } = Astro.props;
---

<div class="mx-auto mt-32 max-w-7xl px-6 sm:mt-56 lg:px-8">
	<div class="mx-auto max-w-2xl lg:text-center">
		<h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">
			{section.eyebrow}
		</h2>
		<p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl lg:text-balance dark:text-white">
			{section.title}
		</p>
		<p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">
			{section.description}
		</p>
	</div>
	<div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none">
		<dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-16 lg:max-w-none lg:grid-cols-3">
			{section.features.map((feature) => (
				<div class="flex flex-col">
					<dt class="text-base/7 font-semibold text-gray-900 dark:text-white">
						<div class="mb-6 flex size-10 items-center justify-center rounded-lg bg-indigo-600 dark:bg-indigo-500">
							<Icon name={feature.icon} class="size-6 text-white" />
						</div>
						{feature.name}
					</dt>
					<dd class="mt-1 flex flex-auto flex-col text-base/7 text-gray-600 dark:text-gray-400">
						<p class="flex-auto">{feature.description}</p>
						{feature.link && (
							<p class="mt-6">
								<a href={resolveHref(feature.link, lang)} class="text-sm/6 font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300">
									{feature.link.label} <span aria-hidden="true">→</span>
								</a>
							</p>
						)}
					</dd>
				</div>
			))}
		</dl>
	</div>
</div>
